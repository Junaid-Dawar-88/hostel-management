generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Warden {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Room {
  id        Int       @id @default(autoincrement())
  number    String    @unique
  floor     Int
  capacity  Int
  createdAt DateTime  @default(now())
  students  Student[]
}

model Student {
  id         Int      @id @default(autoincrement())
  rollNo     String   @unique
  name       String
  fatherName String?
  address    String?
  phone      String?
  guardPhone String?
  cnic       String?
  email      String?
  course     String?
  feesPaid   Boolean  @default(false)
  roomId     Int?
  room       Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}
